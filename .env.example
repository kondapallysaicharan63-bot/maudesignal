# ===========================
# MaudeSignal environment variables template
# ===========================
# Per NFR-07 (Doc 3 §4.3): API keys are loaded from env vars only.
# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed.

# --- Provider selection (REQUIRED) ---
# Choose one: groq | anthropic | openai | gemini | pool
# Default is groq because it has a genuinely free tier. Use 'pool' for
# automatic multi-key fallback on rate-limit errors (see bottom of file).
LLM_PROVIDER=groq

# ===========================
# Groq (FREE TIER — default)
# ===========================
# Free tier: ~30 req/min, 14,400 req/day. More than enough for MaudeSignal.
# Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Alternatives: llama-3.1-8b-instant (faster, smaller), mixtral-8x7b-32768

# ===========================
# Anthropic Claude (PAID)
# ===========================
# Pricing: ~$0.02 per extraction with Sonnet, ~$0.001 with Haiku.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL_EXTRACTION=claude-sonnet-4-6
CLAUDE_MODEL_REASONING=claude-opus-4-7

# ===========================
# OpenAI GPT (PAID)
# ===========================
# Note: ChatGPT Plus does NOT grant API credits. API billing is separate.
# Get a key at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Alternatives: gpt-4o (stronger), o1-mini (reasoning)

# ===========================
# openFDA (optional, free)
# ===========================
# Without a key: 240 req/min, 1000/day
# With a key:    120,000/day
# Request one at https://open.fda.gov/apis/authentication
OPENFDA_API_KEY=

# ===========================
# Operational
# ===========================
MAUDESIGNAL_DB_PATH=data/maudesignal.db
MAUDESIGNAL_LOG_LEVEL=INFO

# Cost ceiling — the pipeline auto-stops if spend exceeds this.
# For Groq (free), leave high. For paid providers, set low ($3-5) as a safety net.
MAUDESIGNAL_COST_CEILING_USD=150.00

# ===========================
# Gemini (FREE TIER) + multi-key pool
# ===========================
# Free tier: ~1,500 req/day per key. Add suffixed keys (_2, _3) to extend
# capacity via the pool. Get keys at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_MODEL=gemini-2.5-flash

# Optional second Groq key (extends free-tier daily cap when used via pool).
GROQ_API_KEY_2=

# Pool fallback order. Comma-separated tokens; each maps to an env-var key:
#   gemini  -> GEMINI_API_KEY      gemini2 -> GEMINI_API_KEY_2
#   gemini3 -> GEMINI_API_KEY_3    groq    -> GROQ_API_KEY
#   groq2   -> GROQ_API_KEY_2      openai  -> OPENAI_API_KEY
#   anthropic -> ANTHROPIC_API_KEY
# On a 429 / rate_limit / quota error, pool rotates to the next slot.
# Only used when LLM_PROVIDER=pool.
PROVIDER_FALLBACK_ORDER=gemini,gemini2,gemini3,groq,groq2
