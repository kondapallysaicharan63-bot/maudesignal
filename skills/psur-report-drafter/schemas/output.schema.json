{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PsurReportDrafterOutput",
  "description": "Structured PSUR section draft for an FDA AI/ML medical device.",
  "type": "object",
  "required": [
    "product_code",
    "reporting_period_start",
    "reporting_period_end",
    "drafted_at",
    "skill_name",
    "skill_version",
    "model_used",
    "executive_summary",
    "signal_assessment",
    "sections",
    "recommended_actions",
    "confidence_score"
  ],
  "properties": {
    "product_code": { "type": "string", "minLength": 1 },
    "reporting_period_start": { "type": "string", "format": "date" },
    "reporting_period_end": { "type": "string", "format": "date" },
    "drafted_at": { "type": "string", "format": "date-time" },
    "skill_name": { "type": "string", "const": "psur-report-drafter" },
    "skill_version": { "type": "string" },
    "model_used": { "type": "string" },
    "executive_summary": {
      "type": "string",
      "minLength": 80,
      "maxLength": 800
    },
    "signal_assessment": {
      "type": "string",
      "enum": ["no_signal", "potential_signal", "confirmed_signal"]
    },
    "sections": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["title", "content"],
        "properties": {
          "title": { "type": "string" },
          "content": { "type": "string", "minLength": 50 }
        },
        "additionalProperties": false
      }
    },
    "recommended_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "maxLength": 200 }
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 0.95
    },
    "draft_notes": { "type": "string" }
  },
  "additionalProperties": false
}
