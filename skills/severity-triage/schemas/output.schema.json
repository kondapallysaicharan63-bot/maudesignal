{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SeverityTriageOutput",
  "description": "Output schema for skills/severity-triage v1.0.0",
  "type": "object",
  "required": [
    "maude_report_id",
    "triage_ts",
    "skill_name",
    "skill_version",
    "model_used",
    "severity",
    "severity_rationale",
    "evidence_quotes",
    "maude_event_type",
    "agrees_with_maude_event_type",
    "confidence_score",
    "requires_human_review"
  ],
  "properties": {
    "maude_report_id": {
      "type": "string",
      "description": "Unique MAUDE MDR identifier; matches the input id"
    },
    "triage_ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when triage completed"
    },
    "skill_name": {
      "type": "string",
      "const": "severity-triage"
    },
    "skill_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "model_used": {
      "type": "string",
      "description": "Full model identifier producing this output"
    },
    "severity": {
      "type": "string",
      "enum": [
        "death",
        "serious_injury",
        "malfunction",
        "other",
        "insufficient_information"
      ]
    },
    "severity_rationale": {
      "type": "string",
      "maxLength": 300,
      "description": "Must reference narrative evidence or explicitly state that MAUDE event_type was the basis"
    },
    "evidence_quotes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 200
      },
      "maxItems": 2,
      "description": "Up to 2 short verbatim substrings from the narrative supporting the decision"
    },
    "maude_event_type": {
      "type": "string",
      "description": "Input passthrough — MAUDE's native event_type"
    },
    "agrees_with_maude_event_type": {
      "type": "boolean",
      "description": "True iff the chosen severity maps to the MAUDE event_type per §6 mapping"
    },
    "disagreement_explanation": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "Populated only when agrees_with_maude_event_type is false"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 0.95,
      "description": "Self-assessed triage confidence; capped at 0.95"
    },
    "requires_human_review": {
      "type": "boolean"
    },
    "triage_notes": {
      "type": ["string", "null"],
      "maxLength": 300,
      "description": "Caveats, multi-patient flags, language flags. null if nothing notable."
    }
  },
  "additionalProperties": false
}
